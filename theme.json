{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,

        "layout": {
            "contentSize": "1240px",
            "wideSize": "1440px"
        },

        "color": {
            "custom": false,
            "palette": [
                { "name": "Dark Burgundy", "slug": "dark",        "color": "#58262c" },
                { "name": "Primary",       "slug": "primary",     "color": "#8c3641" },
                { "name": "Coral",         "slug": "coral",       "color": "#d56e68" },
                { "name": "Rose",          "slug": "rose",        "color": "#a05b63" },
                { "name": "Wine",       "slug": "darkest",     "color": "#51141B" },
                { "name": "Cream",         "slug": "cream",       "color": "#FFFEF7" },
                { "name": "Cream Alt",     "slug": "cream-alt",   "color": "#f6f5ea" },
                { "name": "Light",         "slug": "light",       "color": "#f9f6f2" },
                { "name": "Blush",         "slug": "blush",       "color": "#f3d5d8" },
                { "name": "White",         "slug": "white",       "color": "#ffffff" },
                { "name": "Black",         "slug": "black",       "color": "#231f20" },
                { "name": "Border",        "slug": "border",      "color": "#dddcda" },
                { "name": "Alert",         "slug": "alert",       "color": "#ec1c24" },
                { "name": "Transparent",   "slug": "transparent", "color": "transparent" }
            ],
            "gradients": []
        },

        "typography": {
            "defaultFontSizes": false,
            "fontFamilies": [
                {
                    "fontFamily": "'DM Sans', sans-serif",
                    "name": "DM Sans",
                    "slug": "primary"
                },
                {
                    "fontFamily": "'Playfair Display', serif",
                    "name": "Playfair Display",
                    "slug": "secondary"
                }
            ],
            "fontSizes": [
                {
                    "slug": "xs",
                    "name": "X-Small (14px)",
                    "size": "0.875rem"
                },
                {
                    "slug": "sm",
                    "name": "Small (16px)",
                    "size": "1rem"
                },
                {
                    "slug": "base",
                    "name": "Base (18px)",
                    "size": "1.125rem"
                },
                {
                    "slug": "lg",
                    "name": "Large (18→32px)",
                    "size": "clamp(1.125rem, 1.4vw + 0.775rem, 2rem)"
                },
                {
                    "slug": "xl",
                    "name": "X-Large (24→48px)",
                    "size": "clamp(1.5rem, 2.4vw + 0.9rem, 3rem)"
                },
                {
                    "slug": "xxl",
                    "name": "XX-Large (32→60px)",
                    "size": "clamp(2rem, 2.8vw + 1.3rem, 3.75rem)"
                },
                {
                    "slug": "display",
                    "name": "Display (40→72px)",
                    "size": "clamp(2.5rem, 3.2vw + 1.7rem, 4.5rem)"
                }
            ]
        },

        "spacing": {
            "blockGap": false,
            "defaultSpacingSizes": false,
            "spacingSizes": [
                { "slug": "1",  "name": "1  (4px)",  "size": "0.25rem" },
                { "slug": "2",  "name": "2  (8px)",  "size": "0.5rem"  },
                { "slug": "3",  "name": "3  (12px)", "size": "0.75rem" },
                { "slug": "4",  "name": "4  (16px)", "size": "1rem"    },
                { "slug": "5",  "name": "5  (20px)", "size": "1.25rem" },
                { "slug": "6",  "name": "6  (24px)", "size": "1.5rem"  },
                { "slug": "8",  "name": "8  (32px)", "size": "2rem"    },
                { "slug": "10", "name": "10 (40px)", "size": "2.5rem"  },
                { "slug": "12", "name": "12 (48px)", "size": "3rem"    },
                { "slug": "16", "name": "16 (64px)", "size": "4rem"    },
                { "slug": "20", "name": "20 (80px)", "size": "5rem"    },
                { "slug": "24", "name": "24 (96px)", "size": "6rem"    }
            ]
        }
    },

    "styles": {
        "css": ".wp-site-blocks > * + * { margin-block-start: 0; } .is-layout-flow > .alignfull { margin-block-start: 0; }",
        "color": {
            "background": "var(--wp--preset--color--cream)",
            "text": "var(--wp--preset--color--dark)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--primary)",
            "fontSize": "var(--wp--preset--font-size--sm)",
            "lineHeight": "1.5"
        },
        "elements": {
            "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--display)", "fontWeight": "400", "lineHeight": "1.1"  } },
            "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--xxl)",     "fontWeight": "400", "lineHeight": "1.3"  } },
            "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--xl)",      "fontWeight": "400", "lineHeight": "1.3"  } },
            "h4": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--lg)",      "fontWeight": "400", "lineHeight": "1.3"  } },
            "h5": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--base)",    "fontWeight": "400", "lineHeight": "1.3"  } },
            "h6": { "typography": { "fontFamily": "var(--wp--preset--font-family--secondary)", "fontSize": "var(--wp--preset--font-size--sm)",      "fontWeight": "400", "lineHeight": "1.3"  } },
            "link": {
                "color": { "text": "var(--wp--preset--color--primary)" },
                ":hover": { "color": { "text": "var(--wp--preset--color--dark)" } }
            }
        },
        "blocks": {
            "core/navigation": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--xs)",
                    "fontWeight": "400"
                },
                "elements": {
                    "link": {
                        "color": { "text": "var(--wp--preset--color--dark)" },
                        ":hover": { "color": { "text": "var(--wp--preset--color--primary)" } },
                        "typography": { "textDecoration": "none" }
                    }
                }
            },
            "core/site-logo": {
                "spacing": { "margin": { "bottom": "0" } }
            },
            "core/post-featured-image": {
                "border": { "radius": "0.5rem" }
            },
            "core/post-title": {
                "spacing": { "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--2)" } }
            },
            "core/post-date": {
                "color": { "text": "var(--wp--preset--color--rose)" },
                "typography": { "fontSize": "var(--wp--preset--font-size--xs)" }
            },
            "core/post-excerpt": {
                "color": { "text": "var(--wp--preset--color--rose)" },
                "typography": { "fontSize": "var(--wp--preset--font-size--sm)" },
                "spacing": { "margin": { "top": "var(--wp--preset--spacing--2)", "bottom": "var(--wp--preset--spacing--2)" } }
            },
            "core/post-author": {
                "color": { "text": "var(--wp--preset--color--rose)" },
                "typography": { "fontSize": "var(--wp--preset--font-size--xs)" }
            },
            "core/post-tags": {
                "typography": { "fontSize": "var(--wp--preset--font-size--xs)" }
            },
            "core/post-navigation-link": {
                "color": { "text": "var(--wp--preset--color--primary)" },
                "typography": { "fontWeight": "500" }
            },
            "core/query-pagination": {
                "spacing": { "margin": { "top": "var(--wp--preset--spacing--8)" } },
                "elements": {
                    "link": { "color": { "text": "var(--wp--preset--color--primary)" } }
                }
            },
            "core/search": {
                "elements": {
                    "button": {
                        "color": {
                            "background": "var(--wp--preset--color--coral)",
                            "text": "var(--wp--preset--color--white)"
                        }
                    }
                }
            },
            "core/query-title": {
                "typography": { "fontSize": "var(--wp--preset--font-size--xxl)", "fontWeight": "400" },
                "spacing": { "margin": { "bottom": "var(--wp--preset--spacing--6)" } }
            },
            "core/comments": {
                "spacing": { "margin": { "top": "var(--wp--preset--spacing--10)" } }
            },
            "core/comment-template": {
                "spacing": { "padding": { "top": "var(--wp--preset--spacing--6)", "bottom": "var(--wp--preset--spacing--6)" } }
            }
        }
    },

    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" }
    ]
}

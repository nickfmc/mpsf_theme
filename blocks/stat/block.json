{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mpsf/stat",
    "title": "Stat Counter",
    "category": "myblocks",
    "description": "A bold statistic: large number, a short decorative line, and a label. Used in the Quote & Impact section.",
    "keywords": ["stat", "statistic", "number", "counter", "impact"],
    "supports": {
        "html": false,
        "color": { "text": true, "background": false },
        "spacing": { "margin": true, "padding": false },
        "align": false
    },
    "attributes": {
        "number": {
            "type": "string",
            "default": "0"
        },
        "label": {
            "type": "string",
            "default": ""
        }
    },
    "textdomain": "mpsf",
    "editorScript": "file:../../build/stat.js"
}
